# Copy to .env and fill in local secrets.
# Do not commit the real .env.

# Quant DB
QUANT_DB_USER=
QUANT_DB_PASSWORD=

# Git / remote auth
GITHUB_USERNAME=x-access-token
GITHUB_TOKEN=

# Optional runtime overrides
CONTAINER_NAME=openclaw-openclaw-gateway-1
TIME_ZONE=Asia/Seoul
DEV_CHANNEL_ENABLED=1
DEV_CHANNEL_NAME=discord
DEV_CHANNEL_TARGET=channel:1482514790768447590
HEALTH_WAIT_SECONDS=120
CLOUDFLARED_VERSION=2026.2.1
