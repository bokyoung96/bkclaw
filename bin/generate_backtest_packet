#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VENV_PY="$ROOT_DIR/.venv/bin/python"

if [ -x "$VENV_PY" ]; then
  exec "$VENV_PY" "$ROOT_DIR/scripts/generate_backtest_packet.py" "$@"
fi

exec python3 "$ROOT_DIR/scripts/generate_backtest_packet.py" "$@"
