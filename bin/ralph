#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
OMX_BIN="$ROOT_DIR/bin/omx"

if [ $# -eq 0 ]; then
  cat >&2 <<'EOF'
usage:
  ./bin/ralph "task description"
  ./bin/ralph --prd "task description"
  ./bin/ralph --help

notes:
  - prefers globally installed omx when available
  - falls back to repo-local oh-my-codex runtime
EOF
  exit 1
fi

exec "$OMX_BIN" ralph "$@"
