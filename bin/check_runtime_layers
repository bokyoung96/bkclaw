#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../scripts/lib/load_env.sh
. "$ROOT_DIR/scripts/lib/load_env.sh"
load_workspace_env

printf '[runtime]\n'
if command -v python3 >/dev/null 2>&1; then
  printf 'python3=%s\n' "$(command -v python3)"
  python3 --version
else
  printf 'python3=missing\n'
fi

if command -v pip3 >/dev/null 2>&1; then
  printf 'pip3=%s\n' "$(command -v pip3)"
else
  printf 'pip3=not-on-path\n'
fi

if command -v docker >/dev/null 2>&1; then
  printf 'docker=%s\n' "$(command -v docker)"
else
  printf 'docker=not-on-path\n'
fi

printf '\n[workspace]\n'
if [ -d "$ROOT_DIR/.venv" ]; then
  printf 'venv=%s\n' "$ROOT_DIR/.venv"
else
  printf 'venv=missing\n'
fi

if [ -n "${TAVILY_API_KEY:-}" ]; then
  printf 'tavily_env=present\n'
else
  printf 'tavily_env=missing\n'
fi

printf '\n[guidance]\n'
printf '%s\n' 'Interpret missing-on-path separately from missing-in-runtime.'
printf '%s\n' 'Report runtime layer, workspace layer, and project layer separately.'
