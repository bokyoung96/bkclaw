# syntax=docker/dockerfile:1.7

# Transitional image build for 가재.
# Keep docker commit images as rollback snapshots, but move repeatable system setup
# into this Dockerfile. Workspace-level Python packages remain managed in the
# mounted ~/.openclaw/workspace/.venv, because that path is bind-mounted at runtime.

FROM openclaw:local

USER root

ARG CLOUDFLARED_VERSION=2026.2.1
ARG CODEX_CLI_VERSION=0.115.0
ARG GH_CLI_VERSION=2.88.1
ARG OLLAMA_VERSION=0.7.0

RUN set -eux; \
    arch="$(dpkg --print-architecture)"; \
    case "$arch" in \
      amd64) gh_arch="amd64"; ollama_arch="amd64" ;; \
      arm64) gh_arch="arm64"; ollama_arch="arm64" ;; \
      *) echo "Unsupported architecture: $arch" >&2; exit 1 ;; \
    esac; \
    apt-get update; \
    apt-get install -y --no-install-recommends ca-certificates curl tar cloudflared; \
    npm install -g "@openai/codex@${CODEX_CLI_VERSION}"; \
    curl -fsSL "https://github.com/cli/cli/releases/download/v${GH_CLI_VERSION}/gh_${GH_CLI_VERSION}_linux_${gh_arch}.tar.gz" -o /tmp/gh.tgz; \
    tar -xzf /tmp/gh.tgz -C /tmp; \
    install -m 0755 "/tmp/gh_${GH_CLI_VERSION}_linux_${gh_arch}/bin/gh" /usr/local/bin/gh; \
    curl -fsSL "https://ollama.com/download/ollama-linux-${ollama_arch}.tgz?version=${OLLAMA_VERSION}" -o /tmp/ollama.tgz; \
    tar -xzf /tmp/ollama.tgz -C /usr/local; \
    if [ -x /usr/local/ollama ]; then ln -sf /usr/local/ollama /usr/local/bin/ollama; \
    elif [ -x /usr/local/bin/bin/ollama ]; then ln -sf /usr/local/bin/bin/ollama /usr/local/bin/ollama; \
    elif [ -x /usr/local/ollama/bin/ollama ]; then ln -sf /usr/local/ollama/bin/ollama /usr/local/bin/ollama; \
    elif [ -x /usr/local/bin/ollama ]; then true; \
    else find /usr/local -maxdepth 3 -name ollama -type f >&2; exit 1; fi; \
    cloudflared --version; \
    codex --version; \
    gh --version | head -n 1; \
    /usr/local/bin/ollama --version; \
    rm -rf /tmp/gh.tgz "/tmp/gh_${GH_CLI_VERSION}_linux_${gh_arch}" /tmp/ollama.tgz; \
    apt-get clean; \
    rm -rf /var/lib/apt/lists/*

USER node

ENV PATH="/home/node/.openclaw/workspace/bin:/home/node/.local/bin:${PATH}"

LABEL org.opencontainers.image.title="gaejae-openclaw"
LABEL org.opencontainers.image.description="Repeatable OpenClaw image for 가재 with cloudflared preinstalled"
LABEL org.opencontainers.image.source="workspace/Dockerfile.gaejae"
